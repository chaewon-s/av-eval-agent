{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AV Evaluation Run Manifest",
  "type": "object",
  "required": ["run_id", "created_at", "scenario_definition", "artifacts"],
  "properties": {
    "run_id": { "type": "string" },
    "created_at": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["created", "validated", "built", "running", "completed", "failed"]
    },
    "scenario_definition": { "type": "string" },
    "generated_files": {
      "type": "object",
      "properties": {
        "yaml": { "type": "array", "items": { "type": "string" } },
        "python": { "type": "array", "items": { "type": "string" } }
      }
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "logs": { "type": "array", "items": { "type": "string" } },
        "videos": { "type": "array", "items": { "type": "string" } },
        "kpi_results": { "type": "array", "items": { "type": "string" } },
        "dashboard": { "type": "string" },
        "report": { "type": "string" }
      }
    }
  }
}

