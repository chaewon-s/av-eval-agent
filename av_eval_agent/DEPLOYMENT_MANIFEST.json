{
    "package_name":  "av_eval_agent_deploy_package",
    "source_repository":  "https://github.com/chaewon-s/av-eval-agent",
    "package_type":  "local_windows_research_deployment",
    "components":  {
                       "backend":  "FastAPI + LangGraph agent backend",
                       "orchestration":  "n8n workflow JSON templates",
                       "simulator_boundary":  "CARLA/OpenCDA external runtime",
                       "reporting":  "backend report endpoints and generated artifacts",
                       "remote_access":  "optional cloudflared quick tunnel script"
                   },
    "entrypoints":  {
                        "backend_health":  "http://127.0.0.1:8010/health",
                        "n8n_ui":  "http://127.0.0.1:5678",
                        "main_webhook":  "http://127.0.0.1:5678/webhook/av-eval-agent",
                        "async_webhook":  "http://127.0.0.1:5678/webhook/av-eval-agent-async"
                    },
    "deployment_scripts":  [
                               "deploy_scripts/install_windows.ps1",
                               "deploy_scripts/start_backend.ps1",
                               "deploy_scripts/start_n8n_docker.ps1",
                               "deploy_scripts/import_n8n_workflows.ps1",
                               "deploy_scripts/check_health.ps1",
                               "deploy_scripts/run_sample_request.ps1",
                               "deploy_scripts/start_tunnel.ps1",
                               "deploy_scripts/stop_all.ps1"
                           ],
    "notes":  [
                  "Credentials and API keys are intentionally not included.",
                  "Actual CARLA/OpenCDA execution requires a configured simulator environment on the target PC.",
                  "Report-only and dry-run workflows can be tested without CARLA."
              ],
    "source_commit_before_packaging":  "006e64a45f0f02ab26f713a56ffc78f67614f258"
}
